{
	"info": {
		"_postman_id": "c0e9b5f2-98ab-4fd8-b677-8c7634f1e56d",
		"name": "Multi-Tenant SaaS API Key System",
		"description": "Collection to test the API Key system of Huddle Multi-Tenant SaaS. Features endpoints for login (JWT generation), API Key retrieval/regeneration, meetings endpoints, and verification of rate limits and tenant isolation.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Company Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.token) {",
							"    pm.globals.set(\"company_jwt_token\", jsonData.token);",
							"    console.log(\"Saved company_jwt_token global variable.\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"test@huddle.com\",\n    \"password\": \"password123\"\n}"
				},
				"url": {
					"raw": "http://localhost:8000/company/login/",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8000",
					"path": [
						"company",
						"login",
						""
					]
				},
				"description": "Logs in the host/company using email and password, returning a JWT token."
			},
			"response": []
		},
		{
			"name": "Get API Key",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{company_jwt_token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "http://localhost:8000/company/api-key/",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8000",
					"path": [
						"company",
						"api-key",
						""
					]
				},
				"description": "Retrieves the company's API key. Masks the key if it was generated more than 24 hours ago."
			},
			"response": []
		},
		{
			"name": "Generate/Regenerate API Key",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.api_key) {",
							"    pm.globals.set(\"company_api_key\", jsonData.api_key);",
							"    console.log(\"Saved company_api_key global variable.\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{company_jwt_token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"url": {
					"raw": "http://localhost:8000/company/api-key/generate/",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8000",
					"path": [
						"company",
						"api-key",
						"generate",
						""
					]
				},
				"description": "Generates a new API key for the company (overwriting the old one). Rate limited to 5 regenerates per hour."
			},
			"response": []
		},
		{
			"name": "Create Meeting",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "x-api-key",
						"value": "{{company_api_key}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"Strategy Meeting\",\n    \"participants\": [\"engineer1@huddle.com\", \"designer1@huddle.com\"]\n}"
				},
				"url": {
					"raw": "http://localhost:8000/api/meetings/",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8000",
					"path": [
						"api",
						"meetings",
						""
					]
				},
				"description": "Creates a meeting using the company's generated API key (x-api-key header)."
			},
			"response": []
		},
		{
			"name": "List Meetings",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "x-api-key",
						"value": "{{company_api_key}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "http://localhost:8000/api/meetings/",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8000",
					"path": [
						"api",
						"meetings",
						""
					]
				},
				"description": "Lists all meetings for the tenant linked to the provided API Key."
			},
			"response": []
		}
	]
}
