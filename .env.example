# ==========================================
# COMMON DJANGO SETTINGS
# ==========================================
DEBUG=True
SECRET_KEY=django-insecure-change-this-key-to-something-secure
ALLOWED_HOSTS=localhost,127.0.0.1,backend1,backend2,microservice,meeting-service

# ==========================================
# DATABASE SETTINGS (POSTGRES)
# ==========================================
POSTGRES_DB=backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@postgres-db:5432/backend

# ==========================================
# CACHE SETTINGS (REDIS)
# ==========================================
REDIS_HOST=redis-cache
REDIS_PORT=6379

# ==========================================
# SERVICE PORT BINDINGS
# ==========================================
APP1_PORT=3000
APP2_PORT=3001
BACKEND1_PORT=8002
BACKEND2_PORT=8003
MICROSERVICE_PORT=8000
MEETING_SERVICE_PORT=9000

# ==========================================
# SHARED JWT SIGNING KEYS
# ==========================================
JWT_SIGNING_KEY_BACKEND1=secret_key_backend1
JWT_SIGNING_KEY_BACKEND2=secret_key_backend2

# ==========================================
# API KEY FOR INTERNAL COMMUNICATIONS
# ==========================================
API_KEY=huddle123

# ==========================================
# SMTP EMAIL CONFIGURATION (Optional)
# ==========================================
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
